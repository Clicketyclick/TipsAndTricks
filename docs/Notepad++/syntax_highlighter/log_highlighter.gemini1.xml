<NotepadPlus>
    <UserLang name="Log Files Gemini1" ext="log">
        <Settings>
            <Global caseIgnored="no" escapeChar="00" />
            <TreatAsSymbol comment="no" commentLine="no" />
            <Prefix words1="no" words2="no" words3="no" words4="no" words5="no" words6="no" words7="no" words8="no" />
        </Settings>
        <KeywordLists>
            <Keywords name="Delimiters">00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00</Keywords>
            <Keywords name="Folder+">/* &lt;!--</Keywords>
            <Keywords name="Folder-">*/ --&gt;</Keywords>
            <Keywords name="Operators">- : .</Keywords>
            <Keywords name="Comment"> 1/* 2*/ 1&lt;!-- 2--&gt; 0// 0#</Keywords>
            <Keywords name="Words1">ERROR</Keywords>
            <Keywords name="Words2">WARN</Keywords>
            <Keywords name="Words3">INFO</Keywords>
            <Keywords name="Words4">LOG</Keywords>
            <Keywords name="Words5">TRACE</Keywords>
            <Keywords name="Words6">DEBUG</Keywords>
            <Keywords name="Words7"></Keywords>
            <Keywords name="Words8"></Keywords>
        </KeywordLists>
        <Styles>
            <!-- Default Text: Light Grey on Black -->
            <WordsStyle name="DEFAULT" styleID="11" fgColor="E0E0E0" bgColor="000000" fontName="" fontStyle="0" />
            
            <!-- Block Comments -->
            <WordsStyle name="FOLDEROPEN" styleID="12" fgColor="808080" bgColor="000000" fontName="" fontStyle="0" />
            <WordsStyle name="FOLDERCLOSE" styleID="13" fgColor="808080" bgColor="000000" fontName="" fontStyle="0" />
            
            <!-- Keywords (1=ERROR, 2=WARN, 3=INFO, 4=LOG, 5=TRACE, 6=DEBUG) -->
            <WordsStyle name="KEYWORD1" styleID="5" fgColor="FF0000" bgColor="000000" fontName="" fontStyle="1" />
            <WordsStyle name="KEYWORD2" styleID="6" fgColor="FFFF00" bgColor="000000" fontName="" fontStyle="1" />
            <WordsStyle name="KEYWORD3" styleID="7" fgColor="CC99FF" bgColor="000000" fontName="" fontStyle="1" />
            <WordsStyle name="KEYWORD4" styleID="8" fgColor="FFFFFF" bgColor="000000" fontName="" fontStyle="1" />
            <WordsStyle name="KEYWORD5" styleID="9" fgColor="FFA500" bgColor="000000" fontName="" fontStyle="1" />
            <WordsStyle name="KEYWORD6" styleID="10" fgColor="00FFFF" bgColor="000000" fontName="" fontStyle="1" />
            <WordsStyle name="KEYWORD7" styleID="11" fgColor="000000" bgColor="FFFFFF" fontName="" fontStyle="0" />
            <WordsStyle name="KEYWORD8" styleID="12" fgColor="000000" bgColor="FFFFFF" fontName="" fontStyle="0" />
            
            <!-- Timestamp Digits (Green) -->
            <WordsStyle name="NUMBER" styleID="4" fgColor="00FF00" bgColor="000000" fontName="" fontStyle="0" />
            
            <!-- Timestamp Separators (Orange) -->
            <WordsStyle name="OPERATOR" styleID="10" fgColor="FFA500" bgColor="000000" fontName="" fontStyle="1" />
            
            <!-- Line & Block Comment Body (Grey) -->
            <WordsStyle name="DELIMITER1" styleID="14" fgColor="808080" bgColor="000000" fontName="" fontStyle="0" />
            <WordsStyle name="DELIMITER2" styleID="15" fgColor="808080" bgColor="000000" fontName="" fontStyle="0" />
            <WordsStyle name="DELIMITER3" styleID="16" fgColor="808080" bgColor="000000" fontName="" fontStyle="0" />
        </Styles>
    </UserLang>
</NotepadPlus>
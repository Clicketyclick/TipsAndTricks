<NotepadPlus>
    <UserLang name="LogFileFormatter Gemini2" ext="log">
        <Settings>
            <Global caseIgnored="no" />
            <TreatAsSymbol comment="no" commentLine="no" />
            <Prefix words1="no" words2="no" words3="no" words4="no" words5="no" words6="no" />
        </Settings>
        <KeywordLists>
            <Keywords name="Delimiters">000000</Keywords>
            <Keywords name="Folder+"></Keywords>
            <Keywords name="Folder-"></Keywords>
            <Keywords name="Operators">- : .</Keywords>
            <Keywords name="Comment">1 /* 2 &lt;!-- 1 */ 2 --&gt; 0 // 0 #</Keywords>
            <Keywords name="Words1">ERROR</Keywords>
            <Keywords name="Words2">WARN</Keywords>
            <Keywords name="Words3">INFO</Keywords>
            <Keywords name="Words4">LOG</Keywords>
            <Keywords name="Words5">TRACE</Keywords>
            <Keywords name="Words6">DEBUG</Keywords>
        </KeywordLists>
        <Styles>
            <WordsStyle name="DEFAULT" styleID="11" fgColor="FFFFFF" bgColor="000000" fontName="" fontStyle="0" fontSize="" />
            <WordsStyle name="FOLDEROPEN" styleID="12" fgColor="000000" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" />
            <WordsStyle name="FOLDERCLOSE" styleID="13" fgColor="000000" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" />
            <WordsStyle name="KEYWORD1" styleID="5" fgColor="FF0000" bgColor="000000" fontName="" fontStyle="1" fontSize="" />
            <WordsStyle name="KEYWORD2" styleID="6" fgColor="FFFF00" bgColor="000000" fontName="" fontStyle="1" fontSize="" />
            <WordsStyle name="KEYWORD3" styleID="7" fgColor="DDA0DD" bgColor="000000" fontName="" fontStyle="1" fontSize="" />
            <WordsStyle name="KEYWORD4" styleID="8" fgColor="FFFFFF" bgColor="000000" fontName="" fontStyle="1" fontSize="" />
            <WordsStyle name="KEYWORD5" styleID="9" fgColor="FFA500" bgColor="000000" fontName="" fontStyle="1" fontSize="" />
            <WordsStyle name="KEYWORD6" styleID="10" fgColor="00FFFF" bgColor="000000" fontName="" fontStyle="1" fontSize="" />
            <WordsStyle name="COMMENT" styleID="1" fgColor="808080" bgColor="000000" fontName="" fontStyle="0" fontSize="" />
            <WordsStyle name="COMMENT_LINE" styleID="2" fgColor="808080" bgColor="000000" fontName="" fontStyle="0" fontSize="" />
            <WordsStyle name="NUMBER" styleID="4" fgColor="00FF00" bgColor="000000" fontName="" fontStyle="0" fontSize="" />
            <WordsStyle name="OPERATOR" styleID="10" fgColor="FFA500" bgColor="000000" fontName="" fontStyle="1" fontSize="" />
        </Styles>
    </UserLang>
</NotepadPlus>